# ==========================================
# Simple ERP - Variáveis de Ambiente
# ==========================================

# Google Cloud Vision API — Configuração de Credenciais
# Use APENAS UM dos dois métodos abaixo:

# MÉTODO 1: API Key (mais simples, ideal para desenvolvimento)
# Como obter:
#   1. Acesse https://console.cloud.google.com
#   2. Crie um projeto (ou selecione um existente)
#   3. Ative a Cloud Vision API (APIs & Services > Enable APIs)
#   4. Vá em APIs & Services > Credentials
#   5. Clique em "Create Credentials" > "API Key"
#   6. Copie a chave e cole abaixo
GOOGLE_VISION_API_KEY=sua-api-key-aqui

# MÉTODO 2: Service Account (produção, mais seguro)
# Como obter:
#   1. Acesse https://console.cloud.google.com
#   2. Vá em IAM & Admin > Service Accounts
#   3. Crie uma service account
#   4. Adicione a role "Cloud Vision API User"
#   5. Crie uma chave JSON
#   6. Salve o arquivo JSON no servidor e aponte o caminho abaixo
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
