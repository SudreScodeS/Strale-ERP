# ==========================================
# Simple ERP — Variáveis de Ambiente
# ==========================================

# --- Geração de Imagem por IA (Hugging Face) ---
# Gratuito: https://huggingface.co/settings/tokens
# Gera imagens realistas de produtos em tempo real
HUGGINGFACE_API_TOKEN=hf_SEU_TOKEN_AQUI

# --- Análise de Logo (Google Cloud Vision) ---
# Opcional: sem isso, usa análise local com sharp
GOOGLE_VISION_API_KEY=sua_api_key_aqui
# OU
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credentials.json
