# ==========================================
# Strale ERP — Configuração de Ambiente
# ==========================================

# Krea AI API Key (para geração de imagem de produtos)
# Obtenha em: https://www.krea.ai/ → Settings → API Keys
# Necessário para: geração de base neutra (Flux) + refinamento IA (Flux Kontext)
# SEM esta chave: usa fallback local (SVG 3D realista)
KREA_API_KEY=SUA_CHAVE_KREA_AQUI

# Compatibilidade retroativa: aceita também HUGGINGFACE_API_KEY (deprecated)
# HUGGINGFACE_API_KEY=SEU_TOKEN_AQUI
