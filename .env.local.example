# ==========================================
# Simple ERP — Configuração de Ambiente
# ==========================================

# Hugging Face API Key (para geração de imagem de produtos)
# Obtenha em: https://huggingface.co/settings/tokens
# Necessário para: geração de base neutra + refinamento IA (img2img)
# SEM esta chave: usa fallback local (SVG simplificado)
HUGGINGFACE_API_KEY=SEU_TOKEN_AQUI

# Compatibilidade: aceita também HUGGINGFACE_API_TOKEN
# HUGGINGFACE_API_TOKEN=SEU_TOKEN_AQUI
