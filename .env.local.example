# ==========================================
# Strale ERP — Configuração de Ambiente
# ==========================================

# Hugging Face API Token (para geração de imagem via FLUX.1-schnell)
# Obtenha em: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=SEU_TOKEN_AQUI

# JWT Secret (para assinatura de tokens de autenticação)
JWT_SECRET=CHANGE_ME_SECRET

# ==========================================
# Ollama (Assistente com IA local — OPCIONAL)
# ==========================================
# Ollama roda 100% local, sem custo, sem API externa.
# Instale: curl -fsSL https://ollama.com/install.sh | sh
# Baixe um modelo: ollama pull qwen2.5:7b
# 
# Se não configurar, o assistente usa pattern matching (funciona sem Ollama).
# Com Ollama, o assistente entende perguntas livres em linguagem natural.

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ==========================================
# PostgreSQL (OPCIONAL)
# ==========================================
# Se não configurar, o sistema usa JSON files (desenvolvimento).
# Com PostgreSQL, os dados ficam em banco persistente (produção).
# Instale: apt install postgresql / brew install postgresql
# Crie o banco: createdb elitium_erp
# Execute o schema: psql elitium_erp < app/lib/schema.sql

DATABASE_URL=postgresql://user:password@localhost:5432/elitium_erp
